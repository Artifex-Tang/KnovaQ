# ── ragflow ──────────────────────────────────────────────
RAGFLOW_IMAGE=infiniflow/ragflow:v0.18.0
RAGFLOW_HTTP_PORT=8070
RAGFLOW_HTTPS_PORT=8443
SVR_HTTP_PORT=9380
RAGFLOW_DEBUG_PORT1=5678
RAGFLOW_DEBUG_PORT2=5679
RAGFLOW_MCP_PORT=9382

# ── Elasticsearch ────────────────────────────────────────
STACK_VERSION=8.11.3
ES_HOST=es01
ES_PORT=1200
ELASTIC_PASSWORD=infini_rag_flow
MEM_LIMIT=8073741824

# ── MySQL ────────────────────────────────────────────────
MYSQL_VERSION=8.0.39
MYSQL_HOST=mysql
MYSQL_DBNAME=rag_flow
MYSQL_PORT=5455
MYSQL_PASSWORD=infini_rag_flow

# ── MinIO ────────────────────────────────────────────────
MINIO_VERSION=RELEASE.2023-12-20T01-00-02Z
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9002
MINIO_USER=rag_flow
MINIO_PASSWORD=infini_rag_flow

# ── Redis (Valkey) ───────────────────────────────────────
VALKEY_VERSION=8
REDIS_HOST=redis
REDIS_PORT=6380
REDIS_PASSWORD=infini_rag_flow

# ── gaisoft ──────────────────────────────────────────────
GAISOFT_SERVER_PORT=8088
GAISOFT_FRONTEND_PORT=8899

# ── nginx ─────────────────────────────────────────────────
NGINX_VERSION=1.27-alpine

# ── Timezone ─────────────────────────────────────────────
TIMEZONE=Asia/Shanghai

# ── ragflow optional ─────────────────────────────────────
HF_ENDPOINT=
MACOS=0
