# ── Customer identity ─────────────────────────────────────
# PROJECT_NAME=customer-name      # used in container labels (optional)

# ── Ports (override if multiple deployments on same host) ─
# GAISOFT_SERVER_PORT=8080
# GAISOFT_FRONTEND_PORT=8899

# ── Passwords (always set in production) ─────────────────
# MYSQL_PASSWORD=infini_rag_flow
# REDIS_PASSWORD=infini_rag_flow
# ELASTIC_PASSWORD=infini_rag_flow
# MINIO_PASSWORD=infini_rag_flow

# ── Timezone ─────────────────────────────────────────────
# TIMEZONE=Asia/Shanghai
