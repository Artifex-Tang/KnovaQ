# Runtime artifacts — generated by build scripts
gaisoft/jar/*.jar
gaisoft/uploadfile/*
!gaisoft/uploadfile/.gitkeep
gaisoft/nginx/html/*
!gaisoft/nginx/html/.gitkeep
gaisoft/nginx/logs/*
!gaisoft/nginx/logs/.gitkeep
gaisoft/nginx/conf.d/*.conf

# Offline image tarballs
images/*.tar
!images/.gitkeep
