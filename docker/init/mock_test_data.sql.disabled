-- ============================================================
-- 4. 聊天记录 (kb_chat) — 模拟问答对话内容
-- ============================================================

INSERT INTO kb_chat (message_id, chat_id, session_id, content, package_content, reference, create_by, create_time, update_by, update_time, role) VALUES
-- 会话1: RAG检索原理
('msg_001', 'ab7eb24c5f9d11f1914deedb560e8362', 'mock_sess_001', '什么是RAG检索增强生成技术？', NULL, NULL, 'admin', '2026-05-20 09:30:15', 'admin', '2026-05-20 09:30:15', 'user'),
('msg_002', 'ab7eb24c5f9d11f1914deedb560e8362', 'mock_sess_001', 'RAG（Retrieval-Augmented Generation）检索增强生成技术是一种结合信息检索与大语言模型生成的AI技术框架。其核心思想是：在用户提问时，先从知识库中检索相关文档片段，然后将检索结果作为上下文传递给大语言模型，让模型基于真实知识生成回答，从而减少幻觉、提高回答准确性。', NULL, NULL, 'assistant', '2026-05-20 09:30:20', 'assistant', '2026-05-20 09:30:20', 'assistant'),
('msg_003', 'ab7eb24c5f9d11f1914deedb560e8362', 'mock_sess_001', 'RAG和传统搜索引擎有什么区别？', NULL, NULL, 'admin', '2026-05-20 09:35:00', 'admin', '2026-05-20 09:35:00', 'user'),
('msg_004', 'ab7eb24c5f9d11f1914deedb560e8362', 'mock_sess_001', '传统搜索引擎返回文档链接列表，用户需要自行阅读筛选；RAG技术则直接生成自然语言回答，引用知识库原文，提供更精准的答案。RAG结合了检索的准确性和生成的自然语言理解能力，特别适合企业知识库场景。', NULL, NULL, 'assistant', '2026-05-20 09:35:08', 'assistant', '2026-05-20 09:35:08', 'assistant'),

-- 会话2: 知识库文档格式
('msg_005', 'ab7eb24c5f9d11f1914deedb560e8362', 'mock_sess_002', '系统支持哪些文档格式上传？', NULL, NULL, 'admin', '2026-05-21 14:00:10', 'admin', '2026-05-21 14:00:10', 'user'),
('msg_006', 'ab7eb24c5f9d11f1914deedb560e8362', 'mock_sess_002', '本系统支持以下文档格式：1）Word文档（.docx, .doc）；2）PDF文件（.pdf）；3）Excel表格（.xlsx, .xls）；4）纯文本（.txt）；5）Markdown文件（.md）。建议使用PDF或DOCX格式以获得最佳解析效果。', NULL, NULL, 'assistant', '2026-05-21 14:00:18', 'assistant', '2026-05-21 14:00:18', 'assistant'),
('msg_007', 'ab7eb24c5f9d11f1914deedb560e8362', 'mock_sess_002', '上传的文档大小有限制吗？', NULL, NULL, 'admin', '2026-05-21 14:20:00', 'admin', '2026-05-21 14:20:00', 'user'),
('msg_008', 'ab7eb24c5f9d11f1914deedb560e8362', 'mock_sess_002', '单个文档大小建议不超过50MB。文档过大可能导致解析时间较长。对于大型PDF，建议拆分为多个小文件后分别上传。系统会对文档进行自动分块处理，每个分块默认512个token。', NULL, NULL, 'assistant', '2026-05-21 14:20:08', 'assistant', '2026-05-21 14:20:08', 'assistant'),

-- 会话3: 系统部署
('msg_009', 'ab7eb24c5f9d11f1914deedb560e8362', 'mock_sess_003', '系统部署的最低硬件要求是什么？', NULL, NULL, 'admin', '2026-05-22 10:00:10', 'admin', '2026-05-22 10:00:10', 'user'),
('msg_010', 'ab7eb24c5f9d11f1914deedb560e8362', 'mock_sess_003', '系统最低硬件要求：CPU 8核以上，内存32GB以上（运行嵌入模型需要），硬盘200GB以上SSD存储。推荐配置：CPU 16核，内存64GB，硬盘500GB SSD。如果使用本地大模型（如Qwen），建议使用GPU加速，推荐NVIDIA RTX 4090及以上显卡。', NULL, NULL, 'assistant', '2026-05-22 10:00:20', 'assistant', '2026-05-22 10:00:20', 'assistant'),

-- 会话4: API调用
('msg_011', 'ab7eb24c5f9d11f1914deedb560e8362', 'mock_sess_004', '如何调用知识库检索API？', NULL, NULL, 'admin', '2026-05-23 16:00:10', 'admin', '2026-05-23 16:00:10', 'user'),
('msg_012', 'ab7eb24c5f9d11f1914deedb560e8362', 'mock_sess_004', '知识库检索API调用方式：使用HTTP POST请求，endpoint为 /api/v1/retrieval，Header中携带Authorization: Bearer <API_KEY>。请求体包含 question（检索问题）、dataset_ids（知识库ID列表）、top_k（返回结果数量，默认5）。返回结果包含匹配的文档片段、相似度分数和来源信息。', NULL, NULL, 'assistant', '2026-05-23 16:00:22', 'assistant', '2026-05-23 16:00:22', 'assistant'),

-- 会话5: 文档解析
('msg_013', 'ab7eb24c5f9d11f1914deedb560e8362', 'mock_sess_005', '文档解析失败常见原因有哪些？', NULL, NULL, 'admin', '2026-05-25 09:00:10', 'admin', '2026-05-25 09:00:10', 'user'),
('msg_014', 'ab7eb24c5f9d11f1914deedb560e8362', 'mock_sess_005', '文档解析失败常见原因：1）文档为扫描件PDF（纯图片），缺少OCR支持；2）文档包含加密或数字签名保护；3）嵌入模型API余额不足或服务不可用；4）文档编码异常导致乱码；5）文档格式损坏。解决方案：使用文字版PDF、检查API余额、确认嵌入模型服务正常。', NULL, NULL, 'assistant', '2026-05-25 09:00:25', 'assistant', '2026-05-25 09:00:25', 'assistant'),

-- 会话6: 嵌入模型
('msg_015', 'ab7eb24c5f9d11f1914deedb560e8362', 'mock_sess_006', 'BAAI/bge-large-zh和bge-m3有什么区别？', NULL, NULL, 'admin', '2026-05-26 11:00:10', 'admin', '2026-05-26 11:00:10', 'user'),
('msg_016', 'ab7eb24c5f9d11f1914deedb560e8362', 'mock_sess_006', 'BAAI/bge-large-zh-v1.5是中文专用嵌入模型，维度1024，在中文检索任务上表现优异；bge-m3是多语言模型，支持100+语言，维度1024，在跨语言场景下优势明显。对于纯中文知识库推荐bge-large-zh，对中英混合场景推荐bge-m3。系统默认使用bge-large-zh-v1.5本地模型，无需额外API费用。', NULL, NULL, 'assistant', '2026-05-26 11:00:22', 'assistant', '2026-05-26 11:00:22', 'assistant'),

-- 会话7-10: 补充对话
('msg_017', 'ab7eb24c5f9d11f1914deedb560e8362', 'mock_sess_007', '系统支持哪些用户权限级别？', NULL, NULL, 'admin', '2026-05-27 15:00:10', 'admin', '2026-05-27 15:00:10', 'user'),
('msg_018', 'ab7eb24c5f9d11f1914deedb560e8362', 'mock_sess_007', '系统支持三级权限：超级管理员（全部权限）、部门管理员（管理本部门数据和用户）、普通用户（查询和使用知识库）。可通过系统管理菜单的"角色管理"进行自定义角色配置。', NULL, NULL, 'assistant', '2026-05-27 15:00:18', 'assistant', '2026-05-27 15:00:18', 'assistant'),
('msg_019', 'ab7eb24c5f9d11f1914deedb560e8362', 'mock_sess_008', '系统响应慢如何优化？', NULL, NULL, 'admin', '2026-05-28 10:30:10', 'admin', '2026-05-28 10:30:10', 'user'),
('msg_020', 'ab7eb24c5f9d11f1914deedb560e8362', 'mock_sess_008', '系统性能优化建议：1）增加服务器内存，确保嵌入模型有足够运行空间；2）使用SSD存储提高文档IO速度；3）调整分块大小（chunk_token_num）减少不必要的检索范围；4）配置Redis缓存热点查询；5）如有GPU，启用CUDA加速嵌入计算。', NULL, NULL, 'assistant', '2026-05-28 10:30:22', 'assistant', '2026-05-28 10:30:22', 'assistant'),
('msg_021', 'ab7eb24c5f9d11f1914deedb560e8362', 'mock_sess_009', '数据如何备份和恢复？', NULL, NULL, 'admin', '2026-05-29 13:00:10', 'admin', '2026-05-29 13:00:10', 'user'),
('msg_022', 'ab7eb24c5f9d11f1914deedb560e8362', 'mock_sess_009', '数据备份方案：1）MySQL数据库使用mysqldump定期全量备份；2）MinIO对象存储使用mc mirror同步备份；3）Redis使用RDB+AOF持久化。恢复步骤：先恢复MySQL数据，再恢复MinIO文件，最后重启服务。建议每日自动备份，保留7天增量。', NULL, NULL, 'assistant', '2026-05-29 13:00:20', 'assistant', '2026-05-29 13:00:20', 'assistant'),
('msg_023', 'ab7eb24c5f9d11f1914deedb560e8362', 'mock_sess_010', '如何将其他系统的知识库迁移到本系统？', NULL, NULL, 'admin', '2026-05-30 09:00:10', 'admin', '2026-05-30 09:00:10', 'user'),
('msg_024', 'ab7eb24c5f9d11f1914deedb560e8362', 'mock_sess_010', '知识库迁移步骤：1）从源系统导出文档文件（保持原始格式）；2）在目标系统创建知识库并配置嵌入模型；3）批量上传文档（支持API批量导入）；4）等待自动解析完成；5）验证检索结果准确性。注意事项：不同系统嵌入模型不同时，需要重新生成向量，不可直接迁移向量数据。', NULL, NULL, 'assistant', '2026-05-30 09:00:22', 'assistant', '2026-05-30 09:00:22', 'assistant');


-- ============================================================
-- 完成 — 统计插入数量
-- ============================================================
SELECT 'mock_test_data.sql executed successfully' AS status;
SELECT 'kb_source_type' AS tbl, COUNT(*) AS total FROM kb_source_type
UNION ALL SELECT 'kb_source_file', COUNT(*) FROM kb_source_file
UNION ALL SELECT 'kb_session', COUNT(*) FROM kb_session
UNION ALL SELECT 'kb_chat', COUNT(*) FROM kb_chat;
